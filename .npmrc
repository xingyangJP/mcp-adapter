# Hard-enforce the `engines` field in package.json so contributors and CI
engine-strict = true

# Block lifecycle scripts (preinstall/install/postinstall/prepare) from dependencies.
ignore-scripts = true

# Refuse to install package versions younger than this many days. Requires NPM > 11.
min-release-age = 7

# WordPress ecosystem defaults
lockfile-version = 3
prefer-dedupe = true
