# ローカル開発用 — 本番は Secret Manager を使用
# このファイルはリポジトリに含めてよい (.env 本体は gitignore 済み)

# 中央 MCP サーバーへのアクセスキー
WP_CENTRAL_MCP_API_KEY=your-api-key-here

# 登録サイト設定 (JSON 文字列)
WP_SITES_CONFIG={"sites":[{"site_id":"gentleman-loser","url":"https://gentleman-loser.com/wp-json/mcp/mcp-adapter-default-server","auth":"Basic xxxx","name":"Gentleman Loser"}]}

# GCP プロジェクト (Secret Manager 使用時)
GOOGLE_CLOUD_PROJECT=wordpressmcp
